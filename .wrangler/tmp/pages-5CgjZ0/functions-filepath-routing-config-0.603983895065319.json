{
  "routes": [
    {
      "routePath": "/api/admin/bookings/:id",
      "mountPath": "/api/admin/bookings",
      "method": "PATCH",
      "module": [
        "api/admin/bookings/[id].js:onRequestPatch"
      ]
    },
    {
      "routePath": "/api/admin/bookings",
      "mountPath": "/api/admin",
      "method": "GET",
      "module": [
        "api/admin/bookings.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/bookings",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/bookings.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/rooms",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/rooms.js:onRequestGet"
      ]
    }
  ],
  "baseURL": "/"
}